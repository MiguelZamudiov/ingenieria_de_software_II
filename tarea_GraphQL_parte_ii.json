{"info":{"name":"Tarea GraphQL","schema":"https://schema.getpostman.com/json/collection/v2.1.0/collection.json"},"item":[{"name":"Query básica (Todos los continentes)","event":[{"listen":"test","script":{"exec":["pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });","pm.test(\"La respuesta no contiene errores\", function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData).to.not.have.property('errors');","});"]}}],"request":{"method":"POST","body":{"mode":"graphql","graphql":{"query":"query { continents { code name } }"}},"url":{"raw":"https://countries.trevorblades.com/graphql"}}},{"name":"Query con filtro por argumento","event":[{"listen":"test","script":{"exec":["pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });","pm.test(\"El país es Colombia\", function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData.data.country.name).to.eql('Colombia');","});"]}}],"request":{"method":"POST","body":{"mode":"graphql","graphql":{"query":"query { country(code: \"CO\") { name capital currency } }"}},"url":{"raw":"https://countries.trevorblades.com/graphql"}}},{"name":"Query anidada","event":[{"listen":"test","script":{"exec":["pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });","pm.test(\"Trae datos del continente\", function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData.data.country.continent).to.have.property('name');","});"]}}],"request":{"method":"POST","body":{"mode":"graphql","graphql":{"query":"query { country(code: \"MX\") { name continent { name } languages { name native } } }"}},"url":{"raw":"https://countries.trevorblades.com/graphql"}}},{"name":"Query de lista completa","event":[{"listen":"test","script":{"exec":["pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });","pm.test(\"La lista de idiomas no está vacía\", function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData.data.languages.length).to.be.above(0);","});"]}}],"request":{"method":"POST","body":{"mode":"graphql","graphql":{"query":"query { languages { code name native } }"}},"url":{"raw":"https://countries.trevorblades.com/graphql"}}},{"name":"Query combinada","event":[{"listen":"test","script":{"exec":["pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });","pm.test(\"Contiene lista de países del continente\", function () {","    var jsonData = pm.response.json();","    pm.expect(jsonData.data.continent.countries).to.be.an('array');","});"]}}],"request":{"method":"POST","body":{"mode":"graphql","graphql":{"query":"query { continent(code: \"SA\") { name countries { name capital } } }"}},"url":{"raw":"https://countries.trevorblades.com/graphql"}}}]}